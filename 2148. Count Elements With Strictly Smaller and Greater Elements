class Solution {
    public int countElements(int[] nums) {
        int count = 0;
        int min = nums[0];
        int max = nums[0];
        for(int i = 1; i < nums.length; i++) {
            if(nums[i] < min) {
                min = nums[i];
            }
            if(nums[i] > max) {
                max = nums[i];
            }
        }
        for(int n : nums) {
            if(n > min && n < max) {
                count++;
            }
        }
        return count;
    }
}
