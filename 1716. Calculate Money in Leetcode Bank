class Solution {
    public int totalMoney(int n) {
        int sum = 0;
        int start = 1;
        while(n > 0) {
            int curr = start;
            for(int i = 0; i < 7 && n > 0; i++) {
                sum += curr;
                curr++;
                n--;
            }
            start++;
        }
        return sum;
    }
}
