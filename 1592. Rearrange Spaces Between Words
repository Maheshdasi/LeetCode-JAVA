class Solution {
    public String reorderSpaces(String text) {
        int spaces = 0;
        for(char ch : text.toCharArray()) {
            if(ch == ' ') {
                spaces++;
            }
        }

        String[] s = text.trim().split("\\s+");
        int n = s.length;
        if(n == 1) {
            return s[0] + " ".repeat(spaces);
        }

        String div = " ".repeat(spaces / (n - 1));
        String end = " ".repeat(spaces % (n - 1));
        StringBuilder sb = new StringBuilder();
        for(int i = 0; i < n; i++) {
            sb.append(s[i]);
            if(i < n - 1) {
                sb.append(div);
            }
        }
        
        sb.append(end);
        return sb.toString();
    }
}
