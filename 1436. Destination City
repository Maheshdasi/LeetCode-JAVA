class Solution {
    public String destCity(List<List<String>> paths) {
        for(int i = 0; i < paths.size(); i++) {
            if(!connect(paths, paths.get(i), i)) {
                return paths.get(i).get(paths.get(i).size() - 1);
            }
        }
        return "";
    }
    public boolean connect(List<List<String>> paths, List<String> list, int index) {
        for(int i = 0; i < paths.size(); i++) {
            if(i != index && list.get(list.size() - 1).equals(paths.get(i).get(0))) {
                return true;
            }
        }
        return false;
    }
}
