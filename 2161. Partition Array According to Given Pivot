class Solution {
    public int[] pivotArray(int[] nums, int pivot) {
        int[] result = new int[nums.length];
        int idx = 0;
        for(int i = 0; i < nums.length; i++) {
            if(nums[i] < pivot){
                result[idx] = nums[i];
                idx++;
            }
        }
        for(int j = 0; j < nums.length; j++) {
            if(nums[j] == pivot) {
                result[idx] = nums[j];
                idx++;
            }
        }
        for(int k = 0; k < nums.length; k++) {
            if(nums[k] > pivot) {
                result[idx] = nums[k];
                idx++;
            }
        }
        return result;
    }
}
