class Solution {
    public List<String> printVertically(String s) {
        List<String> list = new ArrayList<>();
        String[] str = s.split(" ");
        int max = 0;
        for(int i = 0; i < str.length; i++) {
            if(str[i].length() > max) {
                max = str[i].length();
            }
        }
        for(int j = 0; j < max; j++) {
            list.add(vertical(str, j));
        }
        return list;
    }
    public String vertical(String[] s, int x) {
        StringBuilder sb = new StringBuilder();
        for(int i = 0; i < s.length; i++) {
            if(x > s[i].length() - 1) {
                sb.append(" ");
            }
            else sb.append(s[i].charAt(x));
        }
        return sb.toString().stripTrailing();
    }
}
