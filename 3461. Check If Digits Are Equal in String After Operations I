class Solution {
    public boolean hasSameDigits(String s) {
        while(s.length() != 2) {
            s = fun(s);
        }
        if(s.charAt(0) == s.charAt(1)) {
            return true;
        }
        return false;
    }
    public String fun(String s) {
        StringBuilder sb = new StringBuilder();
        for(int i = 0; i < s.length() - 1; i++) {
            int x = s.charAt(i) - '0';
            int y = s.charAt(i + 1) - '0';
            String str = ((x + y) % 10) + "";
            sb.append(str);
        }
        return sb.toString();
    }
}
