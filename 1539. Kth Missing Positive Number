class Solution {
    public int findKthPositive(int[] arr, int k) {
        int missCount = 0;
        int i = 1;
        int idx = 0;
        while(missCount < k) {
            if(idx < arr.length && arr[idx] == i) {
                idx++;
            }
            else {
                missCount++;
            }
            i++;
        }
        return i - 1;
    }
}
