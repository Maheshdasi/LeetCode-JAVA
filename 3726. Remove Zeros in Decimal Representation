class Solution {
    public long removeZeros(long n) {
        long sum = 0;
        int i = 0;
        while(n != 0) {
            if(n % 10 != 0) {
                sum = (long) (sum + (n % 10) * (Math.pow(10, i)));
                i++;
            }
            n /= 10;
        }
        return sum;
    }
}
