class Solution {
    public int[] searchRange(int[] nums, int target) {
        return new int[] {firstBinarySearch(nums, target), lastBinarySearch(nums, target)};
    }
    public int firstBinarySearch(int[] nums, int target) {
        int start = 0;
        int end = nums.length - 1;
        int min = -1;
        while(start <= end) {
            int mid = start + (end - start) / 2;
            if(nums[mid] == target) {
                min = mid;
                end = mid - 1;
            }
            else if(nums[mid] > target) {
                end = mid - 1;
            }
            else {
                start = mid + 1;
            }
        }
        return min;
    }
    public int lastBinarySearch(int[] nums, int target) {
        int start = 0;
        int end = nums.length - 1;
        int max = -1;
        while(start <= end) {
            int mid = start + (end - start) / 2;
            if(nums[mid] == target) {
                max = mid;
                start = mid + 1;
            }
            else if(nums[mid] > target) {
                end = mid - 1;
            }
            else {
                start = mid + 1;
            }
        }
        return max;
    }
}
