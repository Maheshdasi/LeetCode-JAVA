class Solution {
    public String replaceDigits(String s) {
        StringBuilder sb = new StringBuilder();
        for(int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            if(Character.isDigit(ch)) {
                sb.append((char)(s.charAt(i - 1) + (ch - '0')));
            } else {
                sb.append(ch);
            }
        }
        return sb.toString();
    }
}
