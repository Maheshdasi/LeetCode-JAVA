class Solution {
    public int passwordStrength(String password) {
        HashSet<Character> set = new HashSet<>();
        int strength = 0;
        for(char ch : password.toCharArray()) {
            if(!set.contains(ch)) {
                set.add(ch);
                if(ch >= 'a' && ch <= 'z') {
                    strength++;
                }
                else if(ch >= 'A' && ch <= 'Z') {
                    strength += 2;
                }
                else if(Character.isDigit(ch)) {
                    strength += 3;
                }
                else {
                    strength += 5;
                }
            }
        }
        return strength;
    }
}
