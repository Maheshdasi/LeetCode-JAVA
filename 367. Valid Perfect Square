class Solution {
    public boolean isPerfectSquare(int num) {
        if(num==0 || num==1) {
            return true;
        }
        int start = 1;
        int end = num;
        while(start <= end) {
            int mid = start + (end - start) / 2;
            long sqr = (long) mid * mid;
            if(sqr == num) {
                return true;
            } else if (sqr < num) {
                start = mid + 1;
            } else if (sqr > num) {
                end = mid - 1;
            }
        }
        return false;
    }
}
