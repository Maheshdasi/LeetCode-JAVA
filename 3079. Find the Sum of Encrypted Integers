class Solution {
    public int sumOfEncryptedInt(int[] nums) {
        int sum = 0;
        for(int i = 0; i < nums.length; i++) {
            if(nums[i] > 9) {
                sum += encrypted(nums[i]);
            }
            else sum += nums[i];
        }
        return sum;
    }
    public int encrypted(int n) {
        int x = String.valueOf(n).length();
        int max = 0;
        while(n != 0) {
            if(n % 10 > max) {
                max = n % 10;
            }
            n /= 10;
        }
        StringBuilder s = new StringBuilder();
        for(int i = 0; i < x; i++) {
            s.append("1");
        }
        return max * Integer.valueOf(s.toString());
    }
}
